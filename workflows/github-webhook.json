{
  "id": "github-webhook-processor",
  "name": "GitHub Webhook Processor",
  "version": "2.0.0",
  "trigger": {
    "type": "webhook",
    "source": "github"
  },
  "nodes": [
    {
      "id": "fetch-metadata",
      "type": "fetchMetadata",
      "name": "Fetch Metadata"
    },
    {
      "id": "validate-payload",
      "type": "validatePayload",
      "name": "Validate Payload"
    },
    {
      "id": "transform-data",
      "type": "transformData",
      "name": "Transform Data"
    },
    {
      "id": "log-summary",
      "type": "logSummary",
      "name": "Log Summary"
    },
    {
      "id": "send-notification",
      "type": "sendNotification",
      "name": "Send Notification"
    }
  ],
  "edges": [
    { "from": "fetch-metadata", "to": "transform-data" },
    { "from": "validate-payload", "to": "transform-data" },
    { "from": "transform-data", "to": "log-summary" },
    { "from": "transform-data", "to": "send-notification" }
  ]
}
